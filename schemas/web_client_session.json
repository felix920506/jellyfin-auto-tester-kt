{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jellyfin-auto-tester.local/schemas/web_client_session.json",
  "title": "WebClientSessionToolParameters",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request"
  ],
  "properties": {
    "request": {
      "$ref": "#/$defs/session_request"
    }
  },
  "$defs": {
    "session_request": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command",
        "request_id"
      ],
      "properties": {
        "command": {
          "enum": [
            "start",
            "action",
            "finalize"
          ]
        },
        "request_id": {
          "type": "string",
          "minLength": 1
        },
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "artifacts_root": {
          "type": "string",
          "minLength": 1
        },
        "plan_path": {
          "type": "string",
          "minLength": 1
        },
        "plan_markdown_path": {
          "type": "string",
          "minLength": 1
        },
        "base_url": {
          "type": "string",
          "minLength": 1
        },
        "step_id": {
          "oneOf": [
            {
              "type": "integer"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "role": {
          "enum": [
            "setup",
            "trigger",
            "verify",
            null
          ]
        },
        "action_label": {
          "type": "string",
          "minLength": 1
        },
        "browser_input": {
          "$ref": "#/$defs/browser_input"
        },
        "action": {
          "$ref": "#/$defs/browser_action"
        },
        "success_criteria": {
          "type": "object",
          "additionalProperties": true
        },
        "selector_assertions": {
          "oneOf": [
            {
              "type": "array",
              "items": {
                "$ref": "#/$defs/selector_assertion"
              }
            },
            {
              "type": "object",
              "additionalProperties": {
                "oneOf": [
                  {
                    "$ref": "#/$defs/selector_state"
                  },
                  {
                    "$ref": "#/$defs/selector_assertion_value"
                  }
                ]
              }
            }
          ]
        },
        "capture": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "overall_result": {
          "enum": [
            "reproduced",
            "not_reproduced",
            "inconclusive"
          ]
        },
        "error_summary": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "command": {
                "const": "start"
              }
            },
            "required": [
              "command"
            ]
          },
          "then": {
            "required": [
              "run_id",
              "artifacts_root"
            ],
            "oneOf": [
              {
                "required": [
                  "plan_path"
                ],
                "not": {
                  "anyOf": [
                    {
                      "required": [
                        "plan_markdown_path"
                      ]
                    },
                    {
                      "required": [
                        "base_url"
                      ]
                    }
                  ]
                }
              },
              {
                "required": [
                  "plan_markdown_path"
                ],
                "not": {
                  "anyOf": [
                    {
                      "required": [
                        "plan_path"
                      ]
                    },
                    {
                      "required": [
                        "base_url"
                      ]
                    }
                  ]
                }
              },
              {
                "required": [
                  "base_url"
                ],
                "not": {
                  "anyOf": [
                    {
                      "required": [
                        "plan_path"
                      ]
                    },
                    {
                      "required": [
                        "plan_markdown_path"
                      ]
                    }
                  ]
                }
              }
            ]
          }
        },
        {
          "if": {
            "properties": {
              "command": {
                "const": "action"
              }
            },
            "required": [
              "command"
            ]
          },
          "then": {
            "required": [
              "action"
            ]
          }
        }
      ]
    },
    "browser_input": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "auth": {
          "$ref": "#/$defs/browser_auth"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "timeout_s": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "viewport": {
          "$ref": "#/$defs/browser_viewport"
        },
        "locale": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "browser_auth": {
      "oneOf": [
        {
          "enum": [
            "auto",
            "none"
          ]
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "mode"
          ],
          "properties": {
            "mode": {
              "enum": [
                "auto",
                "none"
              ]
            },
            "username": {
              "type": "string"
            },
            "password": {
              "type": "string"
            }
          }
        }
      ]
    },
    "browser_viewport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "width",
        "height"
      ],
      "properties": {
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "browser_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "enum": [
            "goto",
            "refresh",
            "click",
            "fill",
            "press",
            "select_option",
            "check",
            "uncheck",
            "wait_for",
            "wait_for_text",
            "wait_for_url",
            "wait_for_media",
            "evaluate",
            "screenshot"
          ]
        },
        "target": {
          "$ref": "#/$defs/click_target"
        },
        "selector": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "value": true,
        "text": {
          "type": "string"
        },
        "key": {
          "type": "string",
          "minLength": 1
        },
        "state": {
          "enum": [
            "visible",
            "hidden",
            "attached",
            "detached",
            "playing",
            "paused",
            "ended",
            "errored",
            "none",
            "stopped"
          ]
        },
        "pattern": {
          "type": "string"
        },
        "script": {
          "type": "string"
        },
        "expression": {
          "type": "string"
        },
        "args": true,
        "label": {
          "type": "string",
          "minLength": 1
        },
        "timeout_s": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "wait_until": {
          "enum": [
            "load",
            "domcontentloaded",
            "networkidle",
            "commit"
          ]
        },
        "full_page": {
          "type": "boolean"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "click"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "required": [
              "target"
            ],
            "not": {
              "anyOf": [
                {
                  "required": [
                    "selector"
                  ]
                },
                {
                  "required": [
                    "text"
                  ]
                },
                {
                  "required": [
                    "value"
                  ]
                }
              ]
            }
          }
        }
      ]
    },
    "click_target": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "name"
          ],
          "properties": {
            "kind": {
              "const": "control"
            },
            "name": {
              "type": "string",
              "minLength": 1
            },
            "scope": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "name"
          ],
          "properties": {
            "kind": {
              "const": "link"
            },
            "name": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "name"
          ],
          "properties": {
            "kind": {
              "const": "text"
            },
            "name": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "selector"
          ],
          "properties": {
            "kind": {
              "const": "css"
            },
            "selector": {
              "type": "string",
              "minLength": 1
            },
            "index": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      ]
    },
    "selector_assertion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selector",
        "state"
      ],
      "properties": {
        "selector": {
          "type": "string",
          "minLength": 1
        },
        "state": {
          "$ref": "#/$defs/selector_state"
        }
      }
    },
    "selector_state": {
      "enum": [
        "exists",
        "visible",
        "hidden",
        "attached",
        "detached"
      ]
    },
    "selector_assertion_value": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state"
      ],
      "properties": {
        "selector": {
          "type": "string",
          "minLength": 1
        },
        "state": {
          "$ref": "#/$defs/selector_state"
        }
      }
    }
  }
}
