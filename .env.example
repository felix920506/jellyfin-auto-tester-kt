# Optional GitHub token used by Stage 1 issue fetching to avoid low rate limits.
GITHUB_TOKEN=

# KohakuTerrarium provider auth is managed by `kt login <provider>` and saved
# in the user's local KohakuTerrarium config by default. Only uncomment a key
# here when you intentionally want this process environment to supply provider
# auth instead.
# OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# MIMO_API_KEY=

# Optional local overrides for the execution/report tools.
JF_AUTO_TESTER_ARTIFACTS_ROOT=artifacts
JF_AUTO_TESTER_BROWSER_HEADLESS=auto

# Runtime logging. Logs are mirrored to stderr by default for CLI runs.
JF_AUTO_TESTER_LOG_LEVEL=INFO
JF_AUTO_TESTER_LOG_STDERR=auto
